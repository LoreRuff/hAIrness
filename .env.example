# === AI Harness ===
# Copy to .env and fill in. NEVER commit .env.

# OpenRouter API key — stays server-side, never sent to the browser.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=8787
HOST=0.0.0.0

# Unique id for this node/machine (used later for multi-node sync).
NODE_ID=lxc-debian-01

# SQLite database file
DB_PATH=./data/harness.db

# Optional: OpenRouter attribution headers (recommended by OpenRouter)
OR_SITE_URL=http://localhost:8787
OR_APP_TITLE=AI Harness

# Optional web_search (Tavily). Leave blank to disable the tool.
TAVILY_API_KEY=

# Optional bearer token for /api/* (empty = auth disabled). Generate: openssl rand -hex 24
HARNESS_TOKEN=
# === M6: snapshots & sync ===
# Automatic DB snapshots (minutes, 0 = disabled). Kept in data/snapshots/.
SNAPSHOT_INTERVAL_MIN=360
SNAPSHOT_KEEP=20

# Optional: upload snapshots to Backblaze B2 (S3-compatible). Leave blank to disable.
# npm i @aws-sdk/client-s3   <-- required only if you enable this
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_ENDPOINT=
B2_REGION=auto

# Mirror snapshots to an external dir (outside the repo, survives redeploys). Empty = disabled.
SNAPSHOT_MIRROR_DIR=/root/harness-backups

